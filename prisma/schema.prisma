generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String   @unique
  createdAt DateTime @default(now())
  users     User[]
  wallets   Wallet[] // Opposite relation for shared wallets
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Identity {
  SUPER_ADMIN
  WHITE_LABEL_ADMIN
  ADMIN
  SUB_ADMIN
  SUPPORT_TEAM
  COUNTRY_HEAD
  STATE_PARTNER
  DISTRICT_PARTNER
  BUSINESS_PARTNER
  SAATHI
  MEMBER
  AGENT
  USER
}

model User {
  id           String   @id @default(uuid())
  mobile       String   @unique
  email        String?
  password     String
  fullName     String
  profilePhoto String?
  gender       Gender
  dateOfBirth    DateTime
  identity       Identity @default(USER)
  userType       String   @default("USER")
  approvalStatus String   @default("APPROVED")
  approvedAt     DateTime?
  roleId         String?
  tenantId       String
  parentId     String?
  createdBy    String?
  referredBy   String?
  referralCode String   @unique @default(uuid())
  createdAt    DateTime @default(now())

  parent       User?    @relation("UserHierarchy", fields: [parentId], references: [id])
  children     User[]   @relation("UserHierarchy")

  creator      User?    @relation("UserCreation", fields: [createdBy], references: [id])
  createdUsers User[]   @relation("UserCreation")

  referrer     User?    @relation("UserReferral", fields: [referredBy], references: [id])
  referrals    User[]   @relation("UserReferral")

  roles        UserRole[]
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  membershipApplications MembershipApplication[]
  createdMembershipApplications MembershipApplication[] @relation("ApplicationCreator")
  wallet          Wallet?
  businessProfile BusinessProfile?
  businessApplications BusinessApplication[]
  jobPosts        JobPost[]

  // Scalability & Hierarchy
  path              String?  @default("")
  
  // Membership & Saathi Delegation
  canApproveMembership Boolean @default(false)
  membershipApprovalDelegatedBy String?
  canApproveSaathi     Boolean @default(false)
  saathiApprovalDelegatedBy String?

  // Relations
  saathiApplications     SaathiApplication[] @relation("UserSaathiApps")
  createdSaathiApps      SaathiApplication[] @relation("SaathiCreator")
  businessPartnerApps    BusinessPartnerApplication[]

  @@index([tenantId])
  @@index([parentId])
  @@index([createdBy])
  @@index([path])
  @@index([canApproveMembership])
  @@index([canApproveSaathi])
}

// ... (existing models)

// Business Partner System
model BusinessProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  
  businessName      String
  brandName         String
  ownerName         String
  email             String
  contactNumber1    String
  contactNumber2    String?
  
  companyLogoUrl    String?
  sectorId          String
  sector            Sector   @relation(fields: [sectorId], references: [id])
  
  businessType      Int      @default(0)
  employerType      Int      @default(0)
  
  serviceCharges    Float    @default(0)
  gst               Float    @default(0)
  platformFees      Float    @default(0)
  
  address           Json?    // Stores structured address
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  jobPosts          JobPost[]
}

model BusinessApplication {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  
  businessName      String
  brandName         String
  ownerName         String
  email             String
  contactNumber1    String
  contactNumber2    String?
  
  sectorId          String
  sector            Sector   @relation(fields: [sectorId], references: [id])
  
  amount            Float    @default(0)
  paymentMode       Int      @default(1)
  razorPayReferenceNo String?
  
  address           Json?
  documents         Json?    // Stores array of document objects
  
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason   String?
  approvedBy        String?  // Admin ID
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model JobPost {
  id                String   @id @default(uuid())
  businessId        String
  business          BusinessProfile @relation(fields: [businessId], references: [id])
  creatorId         String
  creator           User     @relation(fields: [creatorId], references: [id])
  
  jobDescription    String
  jobType           Int      @default(0)
  payStructure      Int      @default(0)
  offeredAmount     Float
  
  educationId       String
  education         Education @relation(fields: [educationId], references: [id])
  experience        Int      @default(0)
  
  gender            Gender   @default(OTHER)
  minAge            Int      @default(18)
  maxAge            Int      @default(60)
  
  officeStartTime   String
  officeEndTime     String
  
  address           Json?
  facilities        String[] // Array of facility IDs or names
  
  isJoiningFees     Boolean  @default(false)
  joiningAmount     Float    @default(0)
  joiningFeeReason  Int[]    // Array of reason codes
  
  contactName       String
  contactNumber     String
  isUrgentHiring    Boolean  @default(false)
  noOfOpenings      Int      @default(1)
  shiftType         Int      @default(0)
  weekOffDays       Int[]    // Array of day codes
  
  skillIds          String[] // Array of Skill IDs
  sectorId          String
  sector            Sector   @relation(fields: [sectorId], references: [id])
  jobRoleId         String
  jobRole           JobRole  @relation(fields: [jobRoleId], references: [id])
  
  applicationCloseDate DateTime
  status            String   @default("ACTIVE") // ACTIVE, CLOSED, EXPIRED
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([businessId])
  @@index([sectorId])
}

// Additional Master Data
model Skill {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model JobFacility {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Country {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
}

model State {
  id        String   @id @default(uuid())
  name      String
  countryId String
  isActive  Boolean  @default(true)
}

model District {
  id        String   @id @default(uuid())
  name      String
  stateId   String
  isActive  Boolean  @default(true)
}

model Municipality {
  id         String   @id @default(uuid())
  name       String
  districtId String
  isActive   Boolean  @default(true)
}


model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  targetId  String?
  metadata  Json?
  tenantId  String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
}

model PrabhuApiLog {
  id             String   @id @default(uuid())
  operation      String
  integration    String
  endpointPath   String
  requestMethod  String
  requestPayload Json?
  responsePayload Json?
  statusCode     Int?
  success        Boolean  @default(false)
  errorMessage   String?
  errorPayload   Json?
  userId         String?
  tenantId       String?
  ipAddress      String?
  userAgent      String?
  durationMs     Int?
  createdAt      DateTime @default(now())

  @@index([operation])
  @@index([integration])
  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model OtpCode {
  id        String   @id @default(uuid())
  mobile    String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([mobile])
}

model ImeData {
  id               String   @id @default(uuid())
  name             String
  mobile           String
  relationship     String
  sendAmountInr    Float?
  receiveAmountNpr Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([mobile])
  @@index([createdAt])
}

model PrabhuData {
  id                   String   @id @default(uuid())
  name                 String
  mobile               String
  relationship         String
  purposeOfTransaction String?
  paymentMode          String?
  bankName             String?
  bankBranch           String?
  sendAmountInr        Float?
  receiveAmountNpr     Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([mobile])
  @@index([createdAt])
}

model PrabhuReceiver {
  id           String   @id @default(uuid())
  customerId   String?
  receiverId   String?  @unique
  name         String
  mobile       String
  relationship String?
  gender       String?
  paymentMode  String?
  bankCode     String?
  bankBranchId String?
  accountNumber String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([customerId])
  @@index([mobile])
  @@index([createdAt])
}

model PrabhuSender {
  id             String   @id @default(uuid())
  customerId     String?  @unique
  name           String
  mobile         String
  gender         String?
  dateOfBirth    String?
  address        String?
  city           String?
  district       String?
  state          String?
  nationality    String?
  email          String?
  idType         String?
  idNumber       String?
  idExpiryDate   String?
  idIssuedPlace  String?
  sourceIncomeType String?
  customerType   String?
  status         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([mobile])
  @@index([createdAt])
}

// Membership Configuration
model MembershipConfig {
  id              String   @id @default(uuid())
  membershipPrice Float    @default(100.0)
  currency        String   @default("INR")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Reference Data Models
model Education {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  membershipApplications MembershipApplication[]
  jobPosts               JobPost[]
}

model Sector {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  membershipApplications MembershipApplication[]
  businessProfiles       BusinessProfile[]
  businessApplications   BusinessApplication[]
  jobPosts               JobPost[]
}

model JobRole {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  membershipApplications MembershipApplication[]
  jobPosts               JobPost[]
}

model DocumentType {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  membershipDocuments MembershipDocument[]
}

// Membership Application
model MembershipApplication {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  
  // Personal Information
  firstName         String
  lastName          String
  email             String
  mobile            String?
  gender            String
  educationId       String
  education         Education @relation(fields: [educationId], references: [id])
  sectorId          String
  sector            Sector    @relation(fields: [sectorId], references: [id])
  jobRoleId         String
  jobRole           JobRole   @relation(fields: [jobRoleId], references: [id])
  maritalStatus     String
  citizenship       String
  isMigrantWorker   Boolean
  monthlyIncome     String
  
  // New API Fields
  profilePhoto      String?
  imageName         String?
  incomeAboveThreshold Boolean @default(false)
  razorPayReferenceNo  String?
  platformFees      Float   @default(0)
  gst               Float   @default(0)
  serviceCharge     Float   @default(0)
  paymentMode       Int     @default(1)
  tnxStatus         Int     @default(0)
  
  addressesJson     Json?
  documentsJson     Json?
  
  // Current Address
  currentCountry    String
  currentState      String
  currentDistrict   String
  currentAddress    String
  currentPincode    String
  
  // Permanent Address
  permanentCountry  String
  permanentState    String
  permanentDistrict String
  permanentAddress  String
  permanentPincode  String
  
  // Application Status
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason   String?
  approvedAt        DateTime?
  approvedBy        String?
  
  createdById       String?   // The admin/partner who filled the form (Method 2)
  creator           User?     @relation("ApplicationCreator", fields: [createdById], references: [id])
  paymentType       String    @default("RAZORPAY") // RAZORPAY, WALLET
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Payment & Documents
  payment           MembershipPayment?
  documents         MembershipDocument[]
  
  @@index([userId])
  @@index([status])
  @@index([createdById])
}

model MembershipPayment {
  id                String   @id @default(uuid())
  applicationId     String   @unique
  application       MembershipApplication @relation(fields: [applicationId], references: [id])
  razorpayOrderId   String
  razorpayPaymentId String?
  razorpaySignature String?
  amount            Float
  currency          String   @default("INR")
  status            String   @default("PENDING") // PENDING, SUCCESS, FAILED
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([applicationId])
  @@index([razorpayOrderId])
}

model MembershipDocument {
  id                String   @id @default(uuid())
  applicationId     String
  application       MembershipApplication @relation(fields: [applicationId], references: [id])
  documentTypeId    String
  documentType      DocumentType @relation(fields: [documentTypeId], references: [id])
  documentNumber    String
  frontImageUrl     String
  backImageUrl      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([applicationId])
}

// Business Partner System
model BusinessPartnerApplication {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  
  businessName        String
  brandName           String
  ownerName           String
  email               String?
  contactNumber1      String?
  contactNumber2      String?
  
  companyLogoName     String?
  companyLogoBase64   String?
  companyLogoUrl      String?
  
  sectorId            String?
  bussinessType       Int      @default(0)
  employeerType       Int      @default(0)
  
  serviceCharges      Float    @default(0)
  gst                 Float    @default(0)
  platformFees        Float    @default(0)
  amount              Float    @default(0)
  
  razorPayReferenceNo String?
  paymentMode         Int      @default(1)
  
  addressJson         Json?
  documentsJson       Json?
  
  status              String   @default("PENDING")
  rejectionReason     String?
  approvedBy          String?
  createdById         String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@index([userId])
}


// Wallet System Models
model Wallet {
  id          String   @id @default(uuid())
  userId      String?  @unique // Null for Corporate/Shared wallets
  user        User?    @relation(fields: [userId], references: [id])
  tenantId    String   // Link to the organization
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  isCorporate Boolean  @default(false) // True for ADMIN/SUB_ADMIN shared wallet
  
  balance     Float    @default(0.0)
  currency    String   @default("INR")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topUpRequests WalletTopUpRequest[]

  @@index([userId])
  @@index([tenantId])
  @@index([isCorporate])
}

model BankDetails {
  id              String   @id @default(uuid())
  bankName        String
  beneficiaryName String
  accountNumber   String
  branch          String
  ifscCode        String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  topUpRequests   WalletTopUpRequest[]

  @@index([isActive])
}

model WalletTopUpRequest {
  id              String   @id @default(uuid())
  walletId        String
  wallet          Wallet   @relation(fields: [walletId], references: [id])
  bankDetailsId   String
  bankDetails     BankDetails @relation(fields: [bankDetailsId], references: [id])
  
  amount          Float
  depositDate     DateTime
  utrNumber       String
  paymentScreenshot String
  
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason String?
  isResubmitted   Boolean  @default(false)
  approvedBy      String?
  approvedAt      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([walletId])
  @@index([status])
  @@index([utrNumber])
}

// Prabhu Transaction Model
model PrabhuTransaction {
  id                  String   @id @default(uuid())
  customerId          String?
  senderName          String
  senderMobile        String
  receiverId          String
  receiverName        String
  receiverMobile      String
  sendCountry         String   @default("India")
  payoutCountry       String   @default("Nepal")
  paymentMode         String
  transferAmount      String
  sendAmount          String
  sendCurrency        String   @default("INR")
  payAmount           String
  payCurrency         String   @default("NPR")
  exchangeRate        String   @default("1.6")
  serviceCharge       String
  collectedAmount     String
  accountNumber       String   @default("")
  partnerPinNo        String
  remittanceReason    String
  sourceOfFund        String
  cspCode             String
  otpProcessId        String
  otp                 String
  bankCode            String
  bankBranchId        String
  transactionId       String?
  pinNo               String
  responseCode        String   @default("000")
  responseMessage     String   @default("Success")
  transactionStatus   String   @default("Success")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([customerId])
  @@index([pinNo])
  @@index([createdAt])
}

// Saathi System
model SaathiApplication {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation("UserSaathiApps", fields: [userId], references: [id])
  
  // Applicant details snapshot
  fullName          String?
  mobile            String?
  gender            String?
  dateOfBirth       DateTime?
  address           String?

  // New API Fields
  maritalStatus         String?
  citizenship           String?
  isMigrantWorker       Boolean  @default(false)
  incomeAboveThreshold  Boolean  @default(false)
  membershipNumber      String?
  sector                String?
  jobRole               String?
  aadhaarNumber         String?
  panNumber             String?
  
  computerLiteracy      Boolean  @default(false)
  internetAvailability  Boolean  @default(false)
  pcLaptopAvailability  Boolean  @default(false)
  kycStatus             Boolean  @default(false)
  governmentSchemes     Boolean  @default(false)
  travelServices        Boolean  @default(false)
  bankingInsurance      Boolean  @default(false)
  jobServices           Boolean  @default(false)
  indoNepalServices     Boolean  @default(false)
  
  shopName              String?
  
  addressesJson         Json?    
  documentsJson         Json?    
  
  // Status and Approval
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason   String?
  approvedBy        String?
  
  // Creation metadata
  createdById       String   
  creator           User     @relation("SaathiCreator", fields: [createdById], references: [id])
  
  paymentType       String   @default("RAZORPAY") // RAZORPAY, WALLET, CASH
  
  // Relationships
  payment           SaathiPayment?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdById])
}

model SaathiPayment {
  id                String   @id @default(uuid())
  applicationId     String   @unique
  application       SaathiApplication @relation(fields: [applicationId], references: [id])
  
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  
  amount            Float
  currency          String   @default("INR")
  status            String   @default("PENDING") // PENDING, SUCCESS, FAILED
  method            String   // RAZORPAY, WALLET, CASH
  
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([applicationId])
}
