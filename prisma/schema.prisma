generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String   @unique
  createdAt DateTime @default(now())
  users     User[]
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Identity {
  ADMIN
  STATE_PARTNER
  DISTRICT_PARTNER
  AGENT
  USER
}

model User {
  id           String   @id @default(uuid())
  mobile       String   @unique
  password     String
  fullName     String
  gender       Gender
  dateOfBirth  DateTime
  identity     Identity @default(USER)
  tenantId     String
  parentId     String?
  createdBy    String?
  referredBy   String?
  referralCode String   @unique @default(uuid())
  createdAt    DateTime @default(now())

  parent       User?    @relation("UserHierarchy", fields: [parentId], references: [id])
  children     User[]   @relation("UserHierarchy")

  creator      User?    @relation("UserCreation", fields: [createdBy], references: [id])
  createdUsers User[]   @relation("UserCreation")

  referrer     User?    @relation("UserReferral", fields: [referredBy], references: [id])
  referrals    User[]   @relation("UserReferral")

  roles        UserRole[]
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([parentId])
  @@index([createdBy])
  @@index([referredBy])
  @@index([referralCode])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  targetId  String?
  metadata  Json?
  tenantId  String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
}

model PrabhuApiLog {
  id             String   @id @default(uuid())
  operation      String
  integration    String
  endpointPath   String
  requestMethod  String
  requestPayload Json?
  responsePayload Json?
  statusCode     Int?
  success        Boolean  @default(false)
  errorMessage   String?
  errorPayload   Json?
  userId         String?
  tenantId       String?
  ipAddress      String?
  userAgent      String?
  durationMs     Int?
  createdAt      DateTime @default(now())

  @@index([operation])
  @@index([integration])
  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model OtpCode {
  id        String   @id @default(uuid())
  mobile    String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([mobile])
}

model ImeData {
  id               String   @id @default(uuid())
  name             String
  mobile           String
  relationship     String
  sendAmountInr    Float?
  receiveAmountNpr Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([mobile])
  @@index([createdAt])
}
