model SaathiPayment {
  id                String   @id @default(uuid())
  applicationId     String   @unique
  application       SaathiApplication @relation(fields: [applicationId], references: [id])
  
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  
  amount            Float
  currency          String   @default("INR")
  status            String   @default("PENDING") // PENDING, SUCCESS, FAILED
  method            String   // RAZORPAY, WALLET, CASH
  
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([applicationId])
}

// =====================================
// 📘 Commission System Models
// ==============================
model CommissionScheme {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false) // General scheme marker
  
  // Location Targeting
  targetState    String?
  targetCity     String?
  targetPincode  String?
  
  tenantId  String
  users     User[]   @relation("UserCommissionScheme")
  shares    CommissionShare[]
  services  CommissionService[] @relation("SchemeServices")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([targetPincode])
  @@index([targetCity])
  @@index([targetState])
}

model CommissionService {
  id          String   @id @default(uuid())
  name        String
  isActive    Boolean  @default(true)
  tenantId    String?
  schemeId    String?
  scheme      CommissionScheme? @relation("SchemeServices", fields: [schemeId], references: [id])
  subServices CommissionSubService[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schemeId])
  @@index([tenantId])
}

model FormDraft {
  id           String   @id @default(uuid())
  userId       String   // Who is filling the form
  targetMobile String   // Mobile of the person being registered
  formType     String   // 'member', 'saathi', 'business'
  data         Json
  step         Int      @default(1)
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, formType, targetMobile, tenantId])
  @@index([userId])
  @@index([targetMobile])
  @@index([tenantId])
}

model CommissionSubService {
  id          String   @id @default(uuid())
  name        String
  slug        String?
  serviceId   String
  service     CommissionService @relation(fields: [serviceId], references: [id])
  tenantId    String?
  schemeId    String?
  isActive    Boolean  @default(true)
  shares      CommissionShare[]
  transactions TransactionLog[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceId])
  @@index([schemeId])
  @@index([tenantId])
  @@unique([serviceId, slug, schemeId])
}

model CommissionShare {
  id                String   @id @default(uuid())
  schemeId          String
  scheme            CommissionScheme @relation(fields: [schemeId], references: [id])
  subServiceId      String
  subService        CommissionSubService @relation(fields: [subServiceId], references: [id])
  
  commissionType    Int      @default(1) // 1 = Percentage, 2 = Flat
  baseType          Int      @default(1) 
  
  admin             Float    @default(0)
  countryPartner    Float    @default(0) @map("country_partner")
  statePartner      Float    @default(0)
  districtPartner   Float    @default(0)
  saathi            Float    @default(0)
  member            Float    @default(0)
  servicePrice      Float    @default(0)
  referral          Float    @default(0)
  referralMinAmount Float    @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([schemeId, subServiceId])
  @@index([schemeId])
  @@index([subServiceId])
}

model TransactionLog {
  id                  String   @id @default(uuid())
  settlementKey       String?  @unique
  subServiceId        String
  subService          CommissionSubService @relation(fields: [subServiceId], references: [id])
  amount              Float
  transactionDoneById String
  transactionDoneForId String?
  referenceId         String?
  referenceType       String?
  metadata            Json?
  status              String   @default("SUCCESS")
  commissionHistory   CommissionHistory[]
  adminIncome         AdminIncome[]
  createdAt           DateTime @default(now())

  @@index([subServiceId])
  @@index([transactionDoneById])
  @@index([referenceId])
  @@index([referenceType])
}

model CommissionHistory {
  id              String   @id @default(uuid())
  userId          String
  transactionId   String
  transaction     TransactionLog @relation(fields: [transactionId], references: [id])
  amount          Float
  accountType     String   @default("commission") // commission, main
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([transactionId])
}

model AdminIncome {
  id              String   @id @default(uuid())
  transactionId   String
  transaction     TransactionLog @relation(fields: [transactionId], references: [id])
  amount          Float
  type            String   @default("credit") // credit, debit
  createdAt       DateTime @default(now())

  @@index([transactionId])
}

// =====================================
// 📱 App Services & UI Management
// ==============================
model AppSection {
  id           String       @id @default(uuid())
  name         String
  iconUrl      String?
  order        Int          @default(0)
  isActive     Boolean      @default(true)
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  services     AppService[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId])
}

model AppService {
  id            String       @id @default(uuid())
  name          String
  iconUrl       String?
  sectionId     String
  section       AppSection   @relation(fields: [sectionId], references: [id])
  componentName String?      // For frontend routing
  arguments     Json?        // Dynamic config for the service
  order         Int          @default(0)
  isActive      Boolean      @default(true)
  
  permissions   RoleServicePermission[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([sectionId])
}

model RoleServicePermission {
  id          String     @id @default(uuid())
  serviceId   String
  service     AppService @relation(fields: [serviceId], references: [id])
  identity    Identity   // Role that can see this service
  
  createdAt   DateTime   @default(now())

  @@unique([serviceId, identity])
}

// =====================================
// 📢 Admin Content Management
// ==============================
model Poster {
  id          String   @id @default(uuid())
  title       String?
  imageUrl    String
  linkUrl     String?
  screen      String?  @default("HOME") // Where to show
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model Announcement {
  id          String   @id @default(uuid())
  text        String
  type        String   @default("TICKER") // TICKER, BANNER
  isActive    Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  message     String
  imageUrl    String?
  isPopup     Boolean  @default(true)
  isActive    Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// =====================================
// 📝 Survey & Membership Questions
// ==============================
model SurveyQuestion {
  id          String         @id @default(uuid())
  question    String
  type        String         @default("TEXT") // TEXT, SELECT, MULTI_SELECT, RADIO
  options     Json?          // Options for select/radio
  order       Int            @default(0)
  isRequired  Boolean        @default(true)
  isActive    Boolean        @default(true)
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  answers     SurveyAnswer[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId])
}

model SurveyAnswer {
  id          String         @id @default(uuid())
  questionId  String
  question    SurveyQuestion @relation(fields: [questionId], references: [id])
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  answer      String
  createdAt   DateTime       @default(now())

  @@index([questionId])
  @@index([userId])
}

// =====================================
// 💳 Wallet Enhancements
// ==============================
model QRCode {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  isActive    Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model WalletTransaction {
  id          String   @id @default(uuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id])
  amount      Float
  type        String   // CREDIT, DEBIT
  category    String   // TOPUP, REFUND, SERVICE_CHARGE, ADMIN_ADJUSTMENT, COMMISSION
  status      String   @default("SUCCESS")
  referenceId String?  // ID of the related object (e.g. TransactionLog ID)
  description String?
  tags        String[] // Flexible tagging for reporting
  metadata    Json?    // Dynamic txn details
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())

  // Transaction Location Data
  txnState    String?
  txnCity     String?
  txnPincode  String?
  txnLat      Float?
  txnLong     Float?

  @@index([walletId])
  @@index([category])
  @@index([tenantId])
}

model SupportTicket {
  id           String           @id @default(uuid())
  ticketNumber String           @unique // e.g., TKT-1001
  subject      String
  description  String?
  status       TicketStatus     @default(OPEN)
  priority     TicketPriority   @default(MEDIUM)
  
  creatorId    String
  creator      User             @relation("CreatedTickets", fields: [creatorId], references: [id])
  
  assignedToId String
  assignedTo   User             @relation("AssignedTickets", fields: [assignedToId], references: [id])
  
  tenantId     String
  
  messages     SupportMessage[]
  
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  closedAt     DateTime?

  @@index([creatorId])
  @@index([assignedToId])
  @@index([tenantId])
}

model SupportMessage {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
  
  senderId  String
  sender    User     @relation("SentSupportMessages", fields: [senderId], references: [id])
  
  message   String   @db.Text
  fileUrl   String?
  
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([senderId])
}

enum TicketStatus {
  OPEN
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model MarketingContent {
  id                  String         @id @default(uuid())
  type                MarketingType  // BANNER, NOTIFICATION, NOTICE, HOVER, POPUP, RIBBON
  title               String?        // Optional
  content             String?        @db.Text
  imageUrl            String?
  linkUrl             String?
  
  // Targeting
  targetType          TargetType     @default(ALL) // ALL, IDENTITY, BRANCH, SPECIFIC, LOCATION
  targetIdentity      Identity?     // If targetType is IDENTITY
  targetUserId        String?        // If targetType is BRANCH or SPECIFIC
  
  // Advanced Multi-Location Targeting (PostgreSQL String Arrays)
  targetCountries     String[]
  targetStates        String[]
  targetCities        String[]
  targetDistricts     String[]
  targetPincodes      String[]
  
  // Validity period
  startDate           DateTime?
  endDate             DateTime?
  
  isActive            Boolean        @default(false) // Deactivated by default
  isGlobalDeactivated Boolean        @default(false) // Master switch for Super Admin
  
  creatorId           String
  creator             User           @relation("CreatedMarketing", fields: [creatorId], references: [id])
  
  tenantId            String
  
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([creatorId])
  @@index([tenantId])
  @@index([type])
}

enum MarketingType {
  BANNER
  NOTIFICATION
  NOTICE
  HOVER
  POPUP
  RIBBON
}

enum TargetType {
  ALL
  IDENTITY
  BRANCH
  SPECIFIC
  LOCATION
}

model UserLoginLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  ip        String?
  state     String?
  city      String?
  pincode   String?
  lat       Float?
  long      Float?
  
  deviceInfo String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([pincode])
  @@index([createdAt])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserNotifications", fields: [userId], references: [id])
  title       String
  message     String
  type        String   @default("GENERAL") // TRANSFER_REQUEST, WITHDRAWN, COMPLETED
  isRead      Boolean  @default(false)
  metadata    Json?    // Related object IDs
  tenantId    String
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([createdAt])
}

model ServiceFeeConfig {
  id            String   @id @default(uuid())
  serviceType   String   // IME, PRABHU
  amount        Float
  tenantId      String
  updatedAt     DateTime @updatedAt
}

// Access Control & Feature Restriction
model IdentityControl {
  id        String   @id @default(uuid())
  tenantId  String
  identity  Identity
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([tenantId, identity])
  @@index([tenantId])
}

model FeatureRestriction {
  id          String   @id @default(uuid())
  tenantId    String
  identity    Identity
  serviceId   String   // e.g., "PAYOUT", "IME", "MEMBERSHIP_PROVISIONING"
  state       String?  // Optional: restrict to specific state
  district    String?  // Optional: restrict to specific district
  isRestricted Boolean @default(false)
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, identity, serviceId, state, district])
  @@index([tenantId, identity])
}

// =====================================================
// NEW: Unified Application System (runs alongside existing tables)
// ==============================================
model Application {
  id                String   @id @default(uuid())
  userId            String   // Target user (who is being upgraded)
  createdById       String   // Who submitted (self or admin/partner)
  tenantId          String

  targetIdentity    String   // MEMBER, SAATHI, BUSINESS_USER, DISTRICT_PARTNER, etc.
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED, PAYMENT_PENDING
  rejectionReason   String?
  approvedBy        String?
  approvedAt        DateTime?

  // Payment
  paymentMethod     String   @default("RAZORPAY") // FREE, CASH, WALLET, RAZORPAY
  paymentStatus     String   @default("NONE")     // NONE, PENDING, SUCCESS, FAILED
  paymentAmount     Float    @default(0)
  razorpayOrderId   String?
  razorpayPaymentId String?

  // All form data stored as flexible JSON
  submittedData     Json
  metadata          Json?    // Extra internal processing info

  // Geolocation captured at submission time
  geoLat            Float?
  geoLng            Float?
  geoAccuracy       Float?
  geoAddress        String?
  geoCapturedAt     DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation("AppTarget",  fields: [userId],      references: [id])
  creator           User     @relation("AppCreator", fields: [createdById], references: [id])
  tenant            Tenant   @relation(fields: [tenantId], references: [id])

  // NEW: Back-references for layered profiles
  memberProfile     MemberProfile?
  saathiProfile     SaathiProfile?
  partnerProfile    PartnerProfile?

  @@index([userId])
  @@index([tenantId])
  @@index([targetIdentity])
  @@index([status])
  @@index([createdById])
}

// Layered Member Profile — created when MEMBER application is approved
model MemberProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  applicationId        String?  @unique
  membershipApplicationId String? @unique
  membershipApplication MembershipApplication? @relation(fields: [membershipApplicationId], references: [id])
  
  

  maritalStatus        String?
  citizenship          String?
  isMigrantWorker      Boolean  @default(false)
  incomeAboveThreshold Boolean  @default(false)
  monthlyIncome        String?
  occupation           String?
  sectorId             String?
  jobRoleId            String?
  educationId          String?

  currentAddressLine   String?
  currentCity          String?
  currentState         String?
  currentPincode       String?
  currentCountry       String?  @default("India")
  currentAddressType   String?  @default("URBAN")
  currentMunicipality  String?

  permanentAddressLine String?
  permanentCity        String?
  permanentState       String?
  permanentPincode     String?
  permanentCountry     String?  @default("India")
  permanentAddressType String?  @default("URBAN")
  permanentMunicipality String?

  documents            Json?    // Array of { type, number, frontUrl, backUrl }
  profilePhoto         String?
  metadata             Json?

  approvedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User        @relation(fields: [userId],       references: [id])
  application          Application? @relation(fields: [applicationId], references: [id])
}

// Layered Saathi Profile — created when SAATHI application is approved
model SaathiProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  applicationId     String?  @unique

  shopName          String?
  shopType          String?
  gstNumber         String?
  businessRegNumber String?
  yearsOfExperience Int?
  shopOpeningTime   String?
  shopClosingTime   String?

  shopAddressLine   String?
  shopCity          String?
  shopState         String?
  shopPincode       String?
  shopCountry       String?  @default("India")
  shopAddressType   String?  @default("URBAN")
  shopMunicipality  String?

  serviceCategory   String?
  serviceType       String?
  serviceName       String?
  metadata          Json?

  approvedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User        @relation(fields: [userId],       references: [id])
  application       Application? @relation(fields: [applicationId], references: [id])
  saathiApplication SaathiApplication? @relation(fields: [saathiApplicationId], references: [id])
  saathiApplicationId String? @unique
}

// Layered Partner Profile — created when DP/SP/CP/WhiteLabel application is approved
model PartnerProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  applicationId        String?  @unique
  businessPartnerApplicationId String? @unique
  businessPartnerApplication BusinessPartnerApplication? @relation(fields: [businessPartnerApplicationId], references: [id])
  
  

  partnerType          String   // DISTRICT_PARTNER | STATE_PARTNER | COUNTRY_HEAD | WHITE_LABEL_ADMIN

  // White Label Company Info
  companyName          String?
  companyLogoUrl       String?
  companyEmail         String?
  companyMobile        String?
  alternateMobile      String?
  website              String?
  companyRegNumber     String?
  gstNumber            String?
  panNumber            String?

  companyAddressLine   String?
  companyCity          String?
  companyState         String?
  companyPincode       String?
  companyCountry       String?

  adminName            String?
  adminEmail           String?
  adminMobile          String?
  adminAlternateMobile String?
  adminProfilePhoto    String?

  // DP/SP/CP specific
  partnerTypeDetail    String?
  areaOfExpertise      String?
  about                String?
  serviceLocation      String?
  experience           String?

  currentAddressLine   String?
  currentCity          String?
  currentState         String?
  currentPincode       String?
  currentCountry       String?
  currentAddressType   String?
  currentMunicipality  String?

  permanentAddressLine String?
  permanentCity        String?
  permanentState       String?
  permanentPincode     String?
  permanentCountry     String?
  permanentAddressType String?
  permanentMunicipality String?

  documents            Json?
  metadata             Json?

  approvedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User        @relation(fields: [userId],       references: [id])
  application          Application? @relation(fields: [applicationId], references: [id])
}





