# Database
DATABASE_URL="postgresql://user:password@localhost:5432/onlinesaathi?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your_super_secret_jwt_key"
JWT_EXPIRES_IN="15m"

# OTP Configuration
OTP_EXPIRY_SECONDS=120
OTP_RESEND_COOLDOWN=30
OTP_MAX_ATTEMPTS=3

# SMS API Configuration
SMS_API_KEY="your_sms_api_key"
SMS_SENDER_ID="SAATHI"
SMS_TEMPLATE_ID="otp_template_id"

# Server
PORT=3000
NODE_ENV=development
